pkgname=keskos-browsers-meta
pkgver=0.1.0
pkgrel=1
pkgdesc="Meta package for the browser choices supported by KeskOS"
arch=(any)
url="https://github.com/memegeko/keskos"
license=(GPL-3.0-or-later)
depends=(
  firefox
  keskos-browser-startpage
)
# TODO: LibreWolf, Zen Browser, and Brave package names vary between official repos,
# third-party repos, and AUR setups. Keep them as optdepends until the repo server
# decides which package sources it will publish or mirror.
optdepends=(
  'librewolf: LibreWolf when available from your enabled pacman repositories'
  'librewolf-bin: LibreWolf AUR packaging variant used by some KeskOS setups'
  'zen-browser: Zen Browser when available from your enabled pacman repositories'
  'zen-browser-bin: Zen Browser AUR packaging variant used by some KeskOS setups'
  'brave-browser: Brave Browser when available from your enabled pacman repositories'
  'brave-bin: Brave Browser AUR packaging variant used by some KeskOS setups'
  'flatpak: alternative delivery path for browsers that are not available through pacman on this machine'
)
source=()
sha256sums=()

package() {
  :
}
